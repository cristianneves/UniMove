# Copie este arquivo para `.env` e ajuste os valores.
# O `.env` esta no .gitignore — nunca commitar segredos reais.

# ----- Banco de dados -----
DATABASE_URL=jdbc:postgresql://localhost:5432/unimove
DATABASE_USER=unimove
DATABASE_PASSWORD=changeme

# ----- JWT -----
# Gere uma chave de pelo menos 256 bits. Sugestao:
#   openssl rand -base64 48
JWT_SECRET=troque-isto-por-uma-chave-aleatoria-de-256-bits
JWT_EXPIRATION_MS=86400000

# ----- OSRM (API de mapas) -----
# Demo publica — sem SLA. Para producao, considerar self-host via Docker.
OSRM_BASE_URL=https://router.project-osrm.org

# ----- Spring -----
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
