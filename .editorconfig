root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# YAML / JSON / Markdown — indent 2 espacos (convencao)
[*.{yml,yaml,json}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Scripts Windows
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Makefiles exigem tab
[Makefile]
indent_style = tab
